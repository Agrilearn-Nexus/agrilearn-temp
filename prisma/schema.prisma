generator client {
  provider = "prisma-client"
  output   = "../src/.generated/"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  password      String?
  createdAt     DateTime  @default(now())
  emailVerified DateTime?
  image         String?
  updatedAt     DateTime  @updatedAt
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Submissions {
  id                    String              @id @unique @default(uuid(7))
  name                  String
  email                 String              @unique
  phone                 String              @unique
  whatsappNumber        String              @unique
  education             String
  currentDesignation    String
  institute             String
  organization          String
  address               String
  city                  String
  district              String
  postalCode            String
  state                 String
  submissionReferenceId String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  submissionDetail      String              @default("N/A")
  whatsappGroupJoined   Boolean             @default(false)
  failureReason         String?
  status                SubmissionStatus    @default(PROCESSING)
  submissionId          String              @unique
  errorLogs             ErrorLog[]
  payment               Payment?
  submissionReference   SubmissionReference @relation(fields: [submissionReferenceId], references: [id])

  @@index([submissionReferenceId])
}

model SubmissionReference {
  id                String        @id @unique @default(uuid(7))
  type              ReferenceType
  personName        String?
  personDesignation String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  Submissions       Submissions[]

  @@unique([type, personName])
  @@index([type])
}

model Payment {
  id           String      @id @unique @default(uuid(7))
  upiId        String
  paymentDate  DateTime
  upiImageId   String?
  UpiImageUrl  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  amountPaid   Float       @default(0.0)
  submissionId String      @unique
  submission   Submissions @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model EventCounter {
  year  Int @id
  value Int @default(0)
}

model ErrorLog {
  id           String       @id @default(uuid())
  source       String
  message      String
  stack        String?
  metadata     Json?
  submissionId String?
  resolved     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  submission   Submissions? @relation(fields: [submissionId], references: [id])
}

model ContactSubmission {
  id        String      @id @default(uuid())
  name      String
  email     String
  phone     String
  role      ContactRole
  subject   String
  message   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([email])
  @@index([createdAt])
}

model CleanupLog {
  id            String   @id @default(uuid())
  startedAt     DateTime @default(now())
  status        String
  totalR2Files  Int      @default(0)
  linkedDbFiles Int      @default(0)
  orphansFound  Int      @default(0)
  deletedCount  Int      @default(0)
  durationMs    Int      @default(0)
  logs          Json?
}

enum ReferenceType {
  SOCAIL_MEDIA
  WHATSAPP_GROUP
  PERSON
  WEBSITE
  MAIL
}

enum SubmissionStatus {
  PROCESSING
  VALIDATING
  SAVED
  COMPLETED
  FAILED
  PAYMENT_VERIFIED
}

enum ContactRole {
  STUDENT
  FARMER
  PROFESSOR
  ORGANIZATION
  OTHER
}

enum Role {
  USER
  ADMIN
}
